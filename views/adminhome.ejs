<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Admin Home</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body onload="readData()">

<div class="container mt-4">
    <a href="">Logout</a> |
    <a href="">Change Password</a>
    <br><br>

    <button class="btn btn-warning btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#addModal">Add Candidate</button>

    <div id="voting-control-section" class="mt-3"></div>

    <br><br>
    <span id="server-response" class="fw-bold"></span>

    <div class="table-responsive mt-3">
        <table id="mytable" class="table table-bordered table-hover table-striped">
            <thead class="text-center table-dark">
            <tr>
                <th>Name</th><th>Party</th><th>Votes</th>
            </tr>
            </thead>
            <tbody id="table-row" class="text-center">
            <!-- Data load hoga -->
            </tbody>
        </table>
    </div>
</div>


<!-- Modal -->
<div class="modal fade" id="addModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5">Add Candidate</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="e-form">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label for="e-adhaar">Adhaar no:</label>
                            <input type="text" name="e-adhaar" id="e-adhaar" class="form-control" placeholder="Enter Adhaar">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label for="e-name">Name:</label>
                            <input type="text" name="e-name" id="e-name" class="form-control" placeholder="Enter Name">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label for="e-party">Party:</label>
                            <input type="text" name="e-party" id="e-party" class="form-control" placeholder="Enter Party">
                        </div>
                        <div class="col-md-12 text-end">
                            <button type="button" onclick="submitModal()" class="btn btn-warning" data-bs-dismiss="modal">Add Candidate</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>

    async function checkAdminVotingStatus() {
        let res = await fetch('/admin-voting-status');
        let data = await res.json();

        let container = document.getElementById('voting-control-section');

        if (data.systemStatus == 1) {
            container.innerHTML = `<button class="btn btn-danger" onclick="toggleVoting('end')">End Voting</button>`;
        }
        else {
            container.innerHTML = `<button class="btn btn-success" onclick="toggleVoting('start')">Start Voting</button>`;
        }
    }

    async function toggleVoting(action) {
        const url = action === 'start' ? '/start-voting' : '/end-voting';
        let res = await fetch(url, { method: 'POST' });
        let data = await res.json();

        alert(data.message);
        if (!data.error) {
            checkAdminVotingStatus();
            readData();
        }
    }

    window.addEventListener('DOMContentLoaded', checkAdminVotingStatus);
    window.addEventListener('DOMContentLoaded', () => {
        readData();
        setInterval(readData, 5000);
    });

    async function submitModal(){
        let adhaar = document.getElementById('e-adhaar').value;
        let name = document.getElementById('e-name').value;
        let party = document.getElementById('e-party').value;

        if(!adhaar || !name || !party){
            alert("Empty fields!");
            return;
        }

        const url = "/add-record";
        const options = {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ adhaar, name, party })
        }

        try {
            let res = await fetch(url, options);
            let data = await res.json();

            document.getElementById('e-form').reset();
            let ServRes = document.getElementById('server-response');
            ServRes.innerHTML = data.message;

            if(data.error){
                ServRes.className = 'text-danger fw-bold';
            } else {
                ServRes.className = 'text-success fw-bold';
                await readData();
            }

            setTimeout(()=>{
                ServRes.innerHTML = '';
                ServRes.className = '';
            }, 3000);

        } catch(err) {
            console.error("Error:", err);
        }
    }

    async function readData(){
        const url = "/read-records";
        try {
            let res = await fetch(url);
            let data = await res.json();
            if(!data.error){
                renderTable(data.records);
            }
        } catch(err) {
            console.error("Error:", err);
        }
    }

    function renderTable(records){
        let html = '';
        for(let i of records){
            html += `<tr>
                <td>${i.name}</td>
                <td>${i.party}</td>
                <td>${i.votes !== undefined && i.votes !== null ? i.votes : 0}</td>
            </tr>`;
        }
        document.getElementById('table-row').innerHTML = html;
    }
</script>

</body>
</html>